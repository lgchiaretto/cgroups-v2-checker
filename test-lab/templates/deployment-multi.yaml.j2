---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "{{ deploy.name }}"
  namespace: "{{ ns_name }}"
  labels:
    app: "{{ deploy.name }}"
    lab: "{{ lab_prefix }}"
spec:
  replicas: {{ deploy.replicas | default(1) }}
  selector:
    matchLabels:
      app: "{{ deploy.name }}"
  template:
    metadata:
      labels:
        app: "{{ deploy.name }}"
        lab: "{{ lab_prefix }}"
    spec:
{% if deploy.type | default('') == 'init' %}
      initContainers:
        - name: init-setup
          image: "{{ deploy.init_image }}"
          imagePullPolicy: "{{ deploy.init_pull_policy | default('Always') }}"
          command: ["/bin/sh", "-c", "echo init done"]
          resources:
            requests:
              memory: "{{ default_resources.requests.memory }}"
              cpu: "{{ default_resources.requests.cpu }}"
            limits:
              memory: "{{ default_resources.limits.memory }}"
              cpu: "{{ default_resources.limits.cpu }}"
{% endif %}
      containers:
{% if deploy.type | default('') == 'multi' %}
{% for c in deploy.containers %}
        - name: "{{ c.name }}"
          image: "{{ c.image }}"
          imagePullPolicy: "{{ c.pull_policy | default('Always') }}"
          command: ["sleep", "infinity"]
          resources:
            requests:
              memory: "{{ default_resources.requests.memory }}"
              cpu: "{{ default_resources.requests.cpu }}"
            limits:
              memory: "{{ default_resources.limits.memory }}"
              cpu: "{{ default_resources.limits.cpu }}"
{% endfor %}
{% elif deploy.type | default('') == 'init' %}
        - name: app
          image: "{{ deploy.image }}"
          imagePullPolicy: "{{ deploy.pull_policy | default('Always') }}"
          command: ["sleep", "infinity"]
          resources:
            requests:
              memory: "{{ default_resources.requests.memory }}"
              cpu: "{{ default_resources.requests.cpu }}"
            limits:
              memory: "{{ default_resources.limits.memory }}"
              cpu: "{{ default_resources.limits.cpu }}"
{% endif %}
